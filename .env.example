# ── Frontend (Vite) — expostas ao browser ───────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Mostra o painel de teste de assinatura (admin) no Perfil. Deixe AUSENTE ou
# 'false' em produção (build da loja / Vercel) — a Apple/Google reprovam se houver
# ferramenta de teste visível. Use 'true' só em dev local.
# VITE_SHOW_DEV_TOOLS=true

# ── Endpoints de IA (/api) — SOMENTE servidor, nunca expor no browser ────────
# Configure estas no painel da Vercel (Project > Settings > Environment Variables).
# Chave da Anthropic (Claude). SEM prefixo VITE_.
ANTHROPIC_API_KEY=sk-ant-...
# Service role do Supabase (escrita no servidor, ignora RLS). NUNCA commitar.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Opcionais: se ausentes, os endpoints usam VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-public-key

# ── IAP (validação de compra das lojas) — SOMENTE servidor (Vercel) ──────────
# Sem estas, /api/validate-purchase e /api/store-webhook respondem 503 tratado
# (o app não quebra, mas a compra não ativa). Preencher no painel da Vercel.
#
# Apple (App Store Server API — chave .p8 "In-App Purchase"):
# APPLE_IAP_BUNDLE_ID=com.caminare.app
# APPLE_IAP_ISSUER_ID=...               # App Store Connect > Users and Access > Integrations
# APPLE_IAP_KEY_ID=...                  # ID da chave .p8 de IAP
# APPLE_IAP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...   # conteúdo do .p8 (com \n)
# APPLE_IAP_ENV=production              # ou 'sandbox' p/ testes (default: production)
#
# Google (Play Developer API — conta de serviço com acesso ao app):
# GOOGLE_IAP_PACKAGE_NAME=com.caminare.app
# GOOGLE_SERVICE_ACCOUNT_JSON={...}     # JSON da service account (string única)
# GOOGLE_PUBSUB_VERIFICATION_TOKEN=...  # token na URL do push do Pub/Sub (webhook)
